---
import { getCollection, type CollectionEntry } from "astro:content";
import { Icon } from "@twodft/astro-icon/components";
import Heading from "../ui/Heading.astro";
import Button from "../ui/Button.astro";
import ProjectCard from "./ProjectCard.astro";


const projects: CollectionEntry<"projects">[] = await getCollection("projects");

const categories = Array.from(
    new Set(projects.map(p => p.data.type.toLowerCase()))
).sort();
---

<section id="proyectos" class="bg-cream-50 pt-20 pb-10">
    <div class="container mx-auto px-6">
        <!-- Header -->
        <div class="flex flex-col items-center gap-3 mb-10">
            <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-primary-100 text-primary-700 text-xs font-medium tracking-widest uppercase">
                <Icon class="w-4 h-4" name="material-symbols:grid-view-rounded" aria-hidden="true" />
                Portafolio
            </div>
            <Heading text="Proyectos que definen" textGradient="mi visión" level={2} />
        </div>

        <!-- Filter Buttons -->
        <div 
            id="portfolio-filter"
            class="flex justify-center gap-2 flex-wrap mb-10"
            role="group"
            aria-label="Filtrar proyectos"
        >
            <button
                class="filter-btn px-5 py-2 rounded-full text-sm font-medium border border-primary-500 bg-primary-500 text-white transition-colors duration-200 focus:outline-none focus:ring-primary-500 focus:ring-offset-2"
                data-filter="all"
                aria-pressed="true"
            >
                Todos
            </button>

            {categories.map(cat => (
                <button
                    class="filter-btn px-5 py-2 rounded-full text-sm font-medium border border-cream-300 bg-cream-50 text-cream-800 hover:bg-primary-100 hover:border-primary-300 hover:text-primary-700 transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2"
                    data-filter={cat}
                    aria-pressed="false"
                >
                    {cat.charAt(0).toUpperCase() + cat.slice(1)}
                </button>
            ))}
        </div>

        <!-- Portfolio Grid -->
        <div
            id="portfolio-grid"
            class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5"
        >
            {projects.map((proj, i) => (
                <ProjectCard project={proj} index={i} />
            ))}
        </div>

        <!-- View More Button -->
        <div class="flex justify-center mt-12">
            <Button
                text="Ver Portafolio Completo"
                variant="outline"
                iconName="material-symbols:keyboard-arrow-right"
                animatedBorder={true}
                iconAfterText={true}
                link="/PortfolioArquitectoAstro/projects"
                data-astro-prefetch
            />
        </div>
    </div>
</section>

<script>
  const MAX_VISIBLE = 6;

  document.addEventListener("astro:page-load", () => {
    const filterBtns = document.querySelectorAll<HTMLButtonElement>(".filter-btn");
    const cards      = document.querySelectorAll<HTMLElement>(".portfolio-card");

    const ACTIVE   = ["bg-primary-500", "text-white",      "border-primary-500"];
    const INACTIVE = ["bg-cream-50",    "text-cream-800",  "border-cream-300",
                      "hover:bg-primary-100", "hover:border-primary-300", "hover:text-primary-700"];

    function applyFilter(filter: string) {
      let shown = 0;
      cards.forEach(card => {
        const cat     = (card.dataset.category ?? "").toLowerCase();
        const visible = (filter === "all" || cat === filter) && shown < MAX_VISIBLE;
        card.style.display = visible ? "" : "none";
        if (visible) shown++;
      });
    }

    function setActive(target: HTMLButtonElement) {
      filterBtns.forEach(btn => {
        const isTarget = btn === target;
        btn.setAttribute("aria-pressed", String(isTarget));
        if (isTarget) {
          btn.classList.remove(...INACTIVE);
          btn.classList.add(...ACTIVE);
        } else {
          btn.classList.remove(...ACTIVE);
          btn.classList.add(...INACTIVE);
        }
      });
    }

    applyFilter("all");

    filterBtns.forEach(btn => {
      btn.addEventListener("click", () => {
        setActive(btn);
        applyFilter((btn.dataset.filter ?? "all").toLowerCase());
      });
    });
  });
</script>