---
interface Props {
    title: string;
    description: string;
    subtitle: string;
    date: string;
    type?: string;
    badge?: string;
    current?: boolean;
    isLast?: boolean;
}

const { 
  title, 
  subtitle, 
  description, 
  date, 
  type,
  badge,
  current = false,
  isLast = false,
} = Astro.props;
---

<div class="grid grid-cols-[30px_1fr] sm:grid-cols-[50px_1fr] gap-0">
    <!-- Column left -->
    <div class:list={[
        "relative flex flex-col items-end pr-6 pt-0.5",
        isLast ? "pb-0" : "pb-8"
    ]}>
        <!-- Line -->
        {!isLast &&  (
            <div class="absolute right-0 top-2.5 bottom-0 w-px bg-cream-300" />
        )}

        <!-- Dot -->
        <div class="absolute -right-1.25 top-1.5 z-10">
            <div class:list={[
                "w-3 h-3 rounded-full border-2 border-cream-50",
                current ? "bg-primary-700" : "bg-primary-500"
            ]} />
        </div>

        <!-- Time -->
        {type && (
            <span class="text-[10px] text-cream-600 text-right leading-none">
                {type}
            </span>
        )}
    </div>

    <!-- Column right -->
    <div class:list={[
        "pl-6",
        isLast ? "pb-0" : "pb-8"
    ]}>
        <div class:list={[
            "bg-cream-100 border rounded-2xl p-4 transition-colors duration-200",
            "hover:bg-white hover:border-cream-400",
            current ? "border-primary-300" : "border-cream-200"
        ]}>
            <!-- Title + badge -->
            <div class="flex items-start justify-between gap-2 mb-1.5">
                <h3 class="text-sm font-medium text-cream-900 leading-snug">
                    {title}
                </h3>
                {badge && (
                    <span class:list={[
                        "shrink-0 text-[10px] font-medium rounded-full px-2.5 py-0.5",
                        current 
                        ? "bg-primary-200 text-primary-800"
                        : "bg-cream-200 text-cream-700"
                    ]}>
                        {badge}
                    </span>
                )}
            </div>

            <p class="text-xs font-medium text-accent-700 mb-2">
                {subtitle}
            </p>

            <p class="text-xs text-cream-700 leading-relaxed">
                {description}
            </p>
        </div>
    </div>
</div>
