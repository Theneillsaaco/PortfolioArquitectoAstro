---
import Heading from "../ui/Heading.astro"
import { Icon } from "@twodft/astro-icon/components"

const points = [
    { icon: "mdi:lightbulb", title: "Diseño Inteligente", desc: "Cada espacio debe contar una historia única"},
    { icon: "mdi:leaf", title: "Sostenibilidad", desc: "Respeto por el contexto cultural y ambiental" }
];

const skills = [
    { name: "AutoCAD", icon: "mdi:vector-square" },
    { name: "Revit", icon: "mdi:home-modern" },
    { name: "SketchUp", icon: "mdi:cube" },
    { name: "Photoshop", icon: "mdi:brush" },
    { name: "Lumion", icon: "mdi:cube-outline" }
];
---

<section class="bg-cream-50 py-16 lg:py-24">
    <div class="container mx-auto px-6">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
            <!-- Left Visual -->
            <div class="relative rounded-4xl overflow-hidden h-80 sm:h-125 lg:h-140 bg-primary-100">
                <div class="relative w-full h-full rounded-4xl overflow-hidden shadow-xl z-20">
                    <img
                        src="https://images.unsplash.com/photo-1600566753151-384129cf4e3e?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80"
                        alt="Andrys en su estudio"
                        class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"
                        loading="lazy"
                    />
                </div>

                <!-- Decorative Elements -->
                <div class="absolute bottom-4 left-4 flex items-center gap-3 bg-cream-50/90 backdrop-blur-sm border border-cream-200 rounded-2xl px-4 py-3">
                    <div class="w-9 h-9 rounded-xl bg-primary-100 flex items-center justify-center text-primary-700 shrink-0">
                      <Icon name="mdi:trophy" class="w-5 h-5" aria-hidden="true" />
                    </div>
                    <div>
                      <p class="text-xs font-medium text-cream-900 leading-none mb-0.5">
                          15 premios
                      </p>
                      <p class="text-xs text-cream-600">
                          Reconocimientos
                      </p>
                    </div>
                </div>
            </div>
            
            <!-- Right Content -->
            <div class="flex flex-col">
                <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-primary-100 text-primary-700 font-medium tracking-widest uppercase rounded-4xl w-fit mb-6">
                    <Icon class="w-3.5 h-3.5" name="mdi:account" aria-hidden="true" />
                    <span>Sobre mi</span>
                </div>

                <Heading text="Transformando ideas en" textGradient="espacios unicos" level={2} className="mb-4" />

                <p class="text-base text-secondary-600 leading-relaxed mb-6">
                    He desarrollado una filosofía de diseño que combina funcionalidad inteligente, 
                    belleza atemporal y sostenibilidad responsable.
                </p>

                <div class="h-px bg-cream-300 mb-6" />
                
                <!-- Philosophy Points -->
                <div class="flex flex-col gap-3 mb-6">
                    {points.map(point => (
                        <div class="flex items-start gap-4 p-4 bg-cream-100 border border-cream-300 rounded-2xl hover:bg-accent-100 hover:border-accent-300 transition-colors duration-200">
                            <div class="w-10 h-10 rounded-xl flex items-center justify-center text-primary-700 shrink-0">
                                <Icon class="w-5 h-5" name={point.icon} aria-hidden="true" />
                            </div>
                            <div>
                                <h6 class="text-sm font-semibold text-cream-900 mb-0.5">{point.title}</h6>
                                <p class="text-sm text-cream-600 leading-relaxed">{point.desc}</p>
                            </div>
                        </div>
                    ))}
                </div>

                <!-- Skills -->
                <p class="text-xs font-medium text-cream-600 uppercase tracking-widest mb-3">
                    Herramientas
                </p>
                <div class="flex flex-wrap gap-2">
                    {skills.map(skill => (
                        <div class="inline-flex items-center gap-2 px-4 py-2 bg-cream-100 border border-cream-300 rounded-full text-sm text-primary-800 hover:bg-accent-100 hover:border-accent-300 transition-colors duration-200">
                            <Icon name={skill.icon} class="w-4 h-4 text-accent-600" aria-hidden="true" />
                            {skill.name}
                        </div>
                    ))}
                </div>
            </div>
        </div>
    </div>
</section>