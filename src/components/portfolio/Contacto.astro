---
import { Icon } from "@twodft/astro-icon/components";
import Heading from "../ui/Heading.astro";

const contactMethods = [
    {
        label: "Ubicación",
        value: "Bávaro, Punta Cana<br>República Dominicana",
        icon: "material-symbols:location-on",
        href: null,
    },
    {
        label: "Teléfono",
        value: "+1 829 983 2226",
        icon: "material-symbols:phone-enabled",
        href: "tel:+18299832226",
    },
    {
        label: "Email",
        value: "andryssantana2@gmail.com",
        icon: "material-symbols:stacked-email",
        href: "mailto:andryssantana2@gmail.com",
    },
];

const socials = [
    {
        label: "WhatsApp",
        href: "https://wa.me/18299832226",
        icon: "mdi:whatsapp",
        hoverClass: "hover:bg-green-50 hover:border-green-300 hover:text-green-700",
    },
];
---

<section id="contacto" class="py-20 bg-cream-50">
    <div class="container mx-auto px-6 max-w-5xl">
        <!-- Header -->
        <div class="flex flex-col items-center text-center gap-3 mb-10">
            <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-primary-100 text-primary-700 text-xs font-semibold tracking-widest uppercase">
                <Icon class="w-4 h-4" name="material-symbols:chat-bubble-rounded" aria-hidden="true"/>
                Contacto
            </div>

            <Heading text="Ponte en contacto" textGradient="conmigo" level={2} />
            <p class="text-sm text-cream-700 max-w-md leading-relaxed">
                Siempre abierto a colaborar en proyectos creativos, nuevas ideas o simplemente charlar.
            </p>
        </div>

        <!-- CTA -->
        <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 bg-accent-100 border border-primary-200 rounded-2xl px-6 py-5 mb-8">
            <div>
                <p class="text-sm font-medium text-cream-900 mb-0.5">
                    ¿Tienes un proyecto en mente?
                </p>
                <p class="text-xs text-cream-700">
                    Escríbeme y lo conversamos.
                </p>
            </div>
            <a 
                href="mailto:andryssantana2@gmail.com"
                class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-primary-500 text-white text-sm font-medium hover:bg-primary-600 transition-colors duration-200 shrink-0"
            >
                <Icon name="material-symbols:stacked-email" class="w-4 h-4" aria-hidden="true" />
                Enviar email
            </a>
        </div>
        
        <!-- Contact Methods -->
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 mb-10">
            {contactMethods.map(method => {
                const Tag = method.href ? "a" : "div";
                return (
                    <Tag
                        href={method.href ?? undefined}
                        class:list={[
                            "flex items-start gap-4 p-5",
                            "bg-cream-100 border border-cream-200 rounded-2xl",
                            "transition-colors duration-200",
                            method.href
                              ? "hover:bg-white hover:border-cream-400 focus:outline-none focus:ring-2 focus:ring-primary-500"
                              : "cursor-default",
                        ]}
                    >
                        <div class="w-10 h-10 flex items-center justify-center rounded-xl bg-primary-100 text-primary-700 shrink-0">
                            <Icon name={method.icon} class="w-5 h-5" aria-hidden="true" />
                        </div>
                        <div>
                            <p class="text-xs font-medium text-cream-600 uppercase tracking-widest mb-1">
                                {method.label}
                            </p>
                            <p class="text-sm font-medium text-cream-900 leading-snug"
                                set:html={method.value} />
                        </div>
                    </Tag>
                );
            })}
        </div>

        <!-- Social Section -->
        <div class="flex flex-col items-center gap-4">
            <h6 class="text-xs font-medium text-cream-600 uppercase tracking-widest">
                Redes sociales
            </h6>
            <div class="flex gap-3">
                {socials.map(social => (
                    <a
                        href={social.href}
                        target="_blank"
                        rel="noopener noreferrer"
                        aria-label={social.label}
                        class:list={[
                          "w-11 h-11 flex items-center justify-center rounded-xl",
                          "bg-cream-100 border border-cream-200 text-cream-700",
                          "transition-colors duration-200",
                          "focus:outline-none focus:ring-2 focus:ring-primary-500",
                          social.hoverClass,
                        ]}
                    >
                        <Icon name={social.icon} class="w-5 h-5" aria-hidden="true" />
                    </a>
                ))}
            </div>
        </div>
    </div>
</div>