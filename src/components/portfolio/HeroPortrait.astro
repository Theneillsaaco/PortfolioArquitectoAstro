---
import { Icon } from "@twodft/astro-icon/components";

interface Props {
  src: string;
  alt: string;
  location?: string;
  awards?: number;
}

const {
  src,
  alt,
  location = "Santo Domingo",
  awards = 15,
} = Astro.props;
---

<div class="relative overflow-hidden bg-primary-100 h-[55vw] max-h-80 sm:h-[45vw] sm:max-h-96 lg:h-screen lg:max-h-none rounded-4xl">

    <!-- Foto: object-position sube la imagen para mostrar la cara -->
    <img
        src={src}
        alt={alt}
        class="absolute inset-0 w-full h-full object-cover"
        style="object-position: center 5%;"
        loading="eager"
    />

    <!-- Overlay degradado sutil en la base para legibilidad de los tags -->
    <div class="absolute bottom-0 inset-x-0 h-32 bg-linear-to-t from-primary-900/30 to-transparent z-10" />

    <!-- Pill: ubicación -->
    <div class="absolute top-4 left-4 z-20 flex items-center gap-2.5 bg-cream-50/90 backdrop-blur-sm border border-cream-200 rounded-2xl px-3 py-2">
        <div class="w-7 h-7 rounded-lg bg-accent-100 flex items-center justify-center text-accent-700 shrink-0">
            <Icon name="mdi:location-outline" />
        </div>
        <div>
            <p class="text-xs font-medium text-cream-900 leading-none mb-0.5">
                {location}
            </p>
            <p class="text-[10px] text-cream-600">
                República Dominicana
            </p>
        </div>
    </div>

    <!-- Pill: premios — oculta en mobile chico para no saturar -->
    <div class="hidden sm:flex absolute bottom-4 left-1/2 -translate-x-1/2 z-20 items-center gap-2.5 bg-cream-50/90 backdrop-blur-sm border border-cream-200 rounded-2xl px-3 py-2 flex-nowrap">
        <div class="w-7 h-7 rounded-lg bg-primary-100 flex items-center justify-center text-primary-700 shrink-0">
            <Icon name="mdi:check-decagram-outline" />
        </div>
        <div>
            <p class="text-xs font-medium text-cream-900 leading-none mb-0.5">
                {awards} premios
            </p>
            <p class="text-[10px] text-cream-600">
                Reconocimientos
            </p>
        </div>
    </div>
</div>