---
interface Props {
  src: string;
  alt: string;
}

const { src, alt } = Astro.props;
---
<div class="relative hidden lg:flex items-end justify-center bg-primary-100 min-h-screen overflow-hidden">
    <!-- Pills flotantes -->
    <div class="absolute top-12 right-8 flex items-center gap-3 bg-cream-50 border border-cream-200 rounded-2xl px-4 py-3 z-20">
        <div class="w-9 h-9 rounded-xl bg-primary-100 flex items-center justify-center text-primary-700 shrink-0">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
            </svg>
        </div>
        <div>
            <p class="text-xs font-medium text-cream-900 leading-none mb-0.5">
                15 premios
            </p>
            <p class="text-xs text-cream-600">
                Reconocimientos
            </p>
        </div>
    </div>

    <div class="absolute top-36 left-8 flex items-center gap-3 bg-cream-50 border border-cream-200 rounded-2xl px-4 py-3 z-20">
        <div class="w-9 h-9 rounded-xl bg-accent-100 flex items-center justify-center text-accent-700 shrink-0">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
        </div>
        <div>
            <p class="text-xs font-medium text-cream-900 leading-none mb-0.5">
                Santo Domingo
            </p>
            <p class="text-xs text-cream-600">
                República Dominicana
            </p>
        </div>
    </div>
    <div>
        <p class="text-xs font-medium text-cream-900 leading-none mb-0.5">
            Santo Domingo
        </p>
        <p class="text-xs text-cream-600">
            República Dominicana
        </p>
    </div>

    <!-- Foto -->
    <div class="relative z-10 w-72 h-120">
        <div class="absolute inset-x-0 bottom-0 h-105 bg-primary-200 rounded-t-full" />
        <img
            src={src}
            alt={alt}
            class="relative z-10 w-full h-full object-cover object-top"
        />
    </div>

    <!-- Tags de especialidades abajo -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-20 flex items-center gap-2 flex-wrap justify-center px-4">
        {["Residencial", "Comercial", "Interiorismo"].map(tag => (
            <span class="px-3 py-1.5 rounded-full text-xs font-medium bg-cream-50 text-primary-700 border border-cream-200">
                {tag}
            </span>
        ))}
    </div>
</div>